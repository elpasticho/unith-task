# PostgreSQL
DATABASE_URL=postgresql+asyncpg://unith:unith@localhost:5432/unith

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=events
RABBITMQ_QUEUE=events.process

# Enrichment provider: "mock" or "openai"
ENRICHMENT_PROVIDER=mock

# OpenAI (only needed if ENRICHMENT_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Delivery worker
DELIVERY_MAX_ATTEMPTS=10
DELIVERY_POLL_INTERVAL=5
DELIVERY_STALE_IN_FLIGHT_MINUTES=10
DELIVERY_BASE_DELAY_SECONDS=1
DELIVERY_MAX_DELAY_SECONDS=300

# Webhook signing
WEBHOOK_HMAC_SECRET_LENGTH=32
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

# Reconciler
RECONCILER_STALE_MINUTES=5
RECONCILER_INTERVAL_SECONDS=60

# RabbitMQ management API (used by /api/v1/pipeline/stats for queue depth)
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
RABBITMQ_MANAGEMENT_USER=guest
RABBITMQ_MANAGEMENT_PASSWORD=guest
